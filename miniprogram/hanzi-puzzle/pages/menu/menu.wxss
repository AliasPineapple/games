/* pages/menu/menu.wxss */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx 24rpx;
  background: linear-gradient(160deg, #EFF6FF, #BFDBFE);
}
.logo {
  font-size: 80rpx;
  margin-bottom: 4rpx;
}
.title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1D4ED8;
  margin-bottom: 4rpx;
}
.sub {
  font-size: 24rpx;
  color: #93C5FD;
  margin-bottom: 32rpx;
}
.level-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  width: 100%;
  max-width: 720rpx;
}
.level-btn {
  background: #fff;
  border: 4rpx solid #BFDBFE;
  border-radius: 28rpx;
  padding: 20rpx 8rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(29,78,216,.08);
  transition: transform 0.12s;
}
.level-btn:active { transform: scale(0.92); }
.lnum {
  font-size: 20rpx;
  font-weight: 700;
  color: #3B82F6;
  margin-bottom: 2rpx;
}
.lrad {
  font-size: 56rpx;
  line-height: 1.3;
  border-radius: 16rpx;
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.lname {
  font-size: 18rpx;
  color: #94A3B8;
  margin-top: 2rpx;
}
.ldiff {
  font-size: 18rpx;
  color: #CBD5E1;
  margin-top: 4rpx;
}
.lstars {
  font-size: 24rpx;
  min-height: 28rpx;
  color: #F59E0B;
  margin-top: 6rpx;
}
